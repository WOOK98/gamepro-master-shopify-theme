[
  {
    "name": "theme_info",
    "theme_name": "GamePro Master",
    "theme_version": "1.0.0",
    "theme_author": "GamePro Contributors",
    "theme_documentation_url": "https://github.com/your-org/gamepro-shopify-theme",
    "theme_support_url": "https://github.com/WOOK98/gamepro-master-shopify-theme/issues"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "color_primary_bg",
        "label": "Primary background",
        "default": "#0A192F"
      },
      {
        "type": "color",
        "id": "color_card_bg",
        "label": "Card / section background",
        "default": "#1E293B"
      },
      {
        "type": "color",
        "id": "color_accent_cyan",
        "label": "Accent (cyan / teal)",
        "default": "#08D9D6"
      },
      {
        "type": "color",
        "id": "color_accent_red",
        "label": "Accent (red / sale)",
        "default": "#FF2E63"
      },
      {
        "type": "color",
        "id": "color_text_primary",
        "label": "Primary text",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text",
        "default": "#94A3B8"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#64748B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "select",
        "id": "font_heading",
        "label": "Heading font",
        "default": "Playfair Display, serif",
        "options": [
          { "value": "Playfair Display, serif", "label": "Playfair Display (serif)" },
          { "value": "Inter, sans-serif", "label": "Inter (sans-serif)" },
          { "value": "Georgia, serif", "label": "Georgia (serif)" }
        ]
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "default": "Inter, sans-serif",
        "options": [
          { "value": "Inter, sans-serif", "label": "Inter (sans-serif)" },
          { "value": "system-ui, sans-serif", "label": "System default" }
        ]
      }
    ]
  },
  {
    "name": "Hero Settings",
    "settings": [
      {
        "type": "header",
        "content": "Hero Banner"
      },
      {
        "type": "text",
        "id": "hero_brand_name",
        "label": "Brand name",
        "default": "GAMEPRO"
      },
      {
        "type": "text",
        "id": "hero_tagline",
        "label": "Tagline",
        "default": "MASTER"
      },
      {
        "type": "textarea",
        "id": "hero_subtitle",
        "label": "Subtitle",
        "default": "Precision. Not Promises."
      },
      {
        "type": "textarea",
        "id": "hero_description",
        "label": "Description",
        "default": "Engineered for the competitive edge. Hall Effect joysticks, mechanical buttons, and relentless innovation."
      },
      {
        "type": "text",
        "id": "hero_cta_text",
        "label": "CTA button text",
        "default": "EXPLORE COLLECTION"
      },
      {
        "type": "url",
        "id": "hero_cta_link",
        "label": "CTA link"
      },
      {
        "type": "checkbox",
        "id": "hero_particles_enabled",
        "label": "Enable particle background",
        "default": true
      }
    ]
  },
  {
    "name": "Newsletter",
    "settings": [
      {
        "type": "header",
        "content": "Newsletter section"
      },
      {
        "type": "text",
        "id": "newsletter_title",
        "label": "Title",
        "default": "Get MIG updates and offers"
      },
      {
        "type": "textarea",
        "id": "newsletter_description",
        "label": "Description",
        "default": "Sign up for product restocks, setup notes, compatibility updates, and exclusive discounts."
      },
      {
        "type": "checkbox",
        "id": "newsletter_enabled",
        "label": "Show newsletter section",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "shop_follow_enabled",
        "label": "Show Follow on Shop button",
        "default": true
      },
      {
        "type": "url",
        "id": "shop_follow_url",
        "label": "Follow on Shop URL",
        "info": "Paste your Shop app follow/store URL. Falls back to the storefront URL when blank."
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "textarea",
        "id": "seo_default_description",
        "label": "Default meta description",
        "default": "Shop MIG Flash V2, MIG Flash Dumper, Switch 2 accessories, controllers, chargers, adapters, and setup gear from MIG Master."
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social sharing image"
      }
    ]
  },
  {
    "name": "Trust & Social",
    "settings": [
      {
        "type": "header",
        "content": "Footer"
      },
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show payment icons",
        "default": true
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "header",
        "content": "Floating promotion"
      },
      {
        "type": "text",
        "id": "promo_rail_text",
        "label": "Promotion rail text",
        "default": "GET 5% OFF"
      },
      {
        "type": "text",
        "id": "promo_discount_code",
        "label": "Discount code",
        "default": "F9VPVX2JG9KZ"
      },
      {
        "type": "header",
        "content": "Sales badges"
      },
      {
        "type": "checkbox",
        "id": "show_sales_count",
        "label": "Show sales count on products",
        "default": true
      },
      {
        "type": "text",
        "id": "default_sales_count",
        "label": "Fallback sales count",
        "info": "Leave blank to avoid showing unverified sales. Product metafield custom.sales_count is used first.",
        "default": ""
      }
    ]
  }
]
