<section class="mig-brand" aria-labelledby="MigBrandTitle-{{ section.id }}">
  <div class="mig-brand__trust page-width" aria-label="{{ section.settings.trust_label | escape }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust' -%}
        <article class="mig-brand__trust-item" {{ block.shopify_attributes }}>
          <span class="mig-brand__trust-index" aria-hidden="true">0{{ forloop.index }}</span>
          <div>
            <h2>{{ block.settings.title | escape }}</h2>
            <p>{{ block.settings.text | escape }}</p>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="mig-brand__products page-width">
    <div class="mig-brand__heading">
      <div>
        <p class="mig-brand__eyebrow">{{ section.settings.products_eyebrow | escape }}</p>
        <h2 id="MigBrandTitle-{{ section.id }}">{{ section.settings.products_heading | escape }}</h2>
      </div>
      <div class="mig-brand__intro rte">{{ section.settings.products_text }}</div>
    </div>

    <div class="mig-brand__product-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign card_product = block.settings.product -%}
          <article class="mig-brand__product-card" {{ block.shopify_attributes }}>
            <a href="{% if card_product != blank %}{{ card_product.url }}{% else %}{{ block.settings.link | default: routes.all_products_collection_url }}{% endif %}" class="mig-brand__product-link">
              <div class="mig-brand__product-media">
                {%- if card_product != blank and card_product.featured_image != blank -%}
                  {{ card_product.featured_image | image_url: width: 1000 | image_tag: widths: '360, 540, 720, 1000', sizes: '(min-width: 990px) 25vw, 50vw', loading: 'lazy', class: 'mig-brand__product-image', alt: card_product.featured_image.alt }}
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1000 | image_tag: widths: '360, 540, 720, 1000', sizes: '(min-width: 990px) 25vw, 50vw', loading: 'lazy', class: 'mig-brand__product-image', alt: block.settings.image.alt }}
                {%- else -%}
                  <div class="mig-brand__product-placeholder" aria-hidden="true">
                    <span>M</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.badge != blank -%}<span class="mig-brand__badge">{{ block.settings.badge | escape }}</span>{%- endif -%}
              </div>
              <div class="mig-brand__product-body">
                <div>
                  <p class="mig-brand__product-kicker">{{ block.settings.kicker | escape }}</p>
                  <h3>{% if card_product != blank %}{{ card_product.title | escape }}{% else %}{{ block.settings.title | escape }}{% endif %}</h3>
                </div>
                <span class="mig-brand__arrow" aria-hidden="true">↗</span>
                <p class="mig-brand__product-copy">{{ block.settings.text | escape }}</p>
                {%- if card_product != blank -%}<p class="mig-brand__price">{{ card_product.price | money }}</p>{%- endif -%}
              </div>
            </a>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="mig-brand__process">
    <div class="page-width">
      <div class="mig-brand__heading mig-brand__heading--process">
        <div>
          <p class="mig-brand__eyebrow">{{ section.settings.process_eyebrow | escape }}</p>
          <h2>{{ section.settings.process_heading | escape }}</h2>
        </div>
        <div class="mig-brand__intro rte">{{ section.settings.process_text }}</div>
      </div>
      <div class="mig-brand__steps">
        {%- assign step_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            {%- assign step_count = step_count | plus: 1 -%}
            <article class="mig-brand__step" {{ block.shopify_attributes }}>
              <span class="mig-brand__step-number">0{{ step_count }}</span>
              <div class="mig-brand__step-visual" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <h3>{{ block.settings.title | escape }}</h3>
              <p>{{ block.settings.text | escape }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="mig-brand__comparison page-width">
    <div class="mig-brand__comparison-copy">
      <p class="mig-brand__eyebrow">{{ section.settings.comparison_eyebrow | escape }}</p>
      <h2>{{ section.settings.comparison_heading | escape }}</h2>
      <div class="rte">{{ section.settings.comparison_text }}</div>
      {%- if section.settings.comparison_button != blank -%}
        <a href="{{ section.settings.comparison_link | default: routes.all_products_collection_url }}" class="button button--primary">{{ section.settings.comparison_button | escape }}</a>
      {%- endif -%}
    </div>
    <div class="mig-brand__table" role="table" aria-label="{{ section.settings.comparison_heading | escape }}">
      <div class="mig-brand__table-head" role="row">
        <span role="columnheader">{{ section.settings.table_feature | escape }}</span>
        <span role="columnheader">MIG MASTER</span>
        <span role="columnheader">{{ section.settings.table_other | escape }}</span>
      </div>
      {%- for block in section.blocks -%}
        {%- if block.type == 'comparison' -%}
          <div class="mig-brand__table-row" role="row" {{ block.shopify_attributes }}>
            <span role="cell">{{ block.settings.title | escape }}</span>
            <strong role="cell">{{ block.settings.mig_value | escape }}</strong>
            <span role="cell">{{ block.settings.other_value | escape }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="mig-brand__reviews">
    <div class="page-width">
      <div class="mig-brand__heading">
        <div>
          <p class="mig-brand__eyebrow">{{ section.settings.reviews_eyebrow | escape }}</p>
          <h2>{{ section.settings.reviews_heading | escape }}</h2>
        </div>
        <p class="mig-brand__rating">★★★★★ <span>{{ section.settings.rating_text | escape }}</span></p>
      </div>
      <div class="mig-brand__review-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <blockquote class="mig-brand__review" {{ block.shopify_attributes }}>
              <div class="mig-brand__stars" aria-label="5 out of 5 stars">★★★★★</div>
              <p>“{{ block.settings.quote | escape }}”</p>
              <footer>
                <span class="mig-brand__avatar" aria-hidden="true">{{ block.settings.name | slice: 0 | upcase }}</span>
                <span><strong>{{ block.settings.name | escape }}</strong><small>{{ block.settings.meta | escape }}</small></span>
              </footer>
            </blockquote>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div id="discount-code" class="mig-brand__newsletter page-width">
    <div>
      <p class="mig-brand__eyebrow">{{ section.settings.newsletter_eyebrow | escape }}</p>
      <h2>{{ section.settings.newsletter_heading | escape }}</h2>
      <p>{{ section.settings.newsletter_text | escape }}</p>
    </div>
    {%- form 'customer', class: 'mig-brand__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="MigNewsletter-{{ section.id }}">{{ section.settings.email_label | escape }}</label>
      <input id="MigNewsletter-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" autocorrect="off" autocapitalize="off" autocomplete="email" placeholder="{{ section.settings.email_placeholder | escape }}" required>
      <button type="submit">{{ section.settings.newsletter_button | escape }}</button>
      {%- if form.posted_successfully? -%}<p class="mig-brand__form-message" tabindex="-1">{{ section.settings.success_text | escape }}</p>{%- endif -%}
      {%- if form.errors -%}<p class="mig-brand__form-message" tabindex="-1">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</section>

{% stylesheet %}
  .mig-brand { overflow: hidden; color: #eef2f7; background: #05070a; }
  .mig-brand .page-width { max-width: 160rem; }
  .mig-brand__eyebrow { margin: 0 0 1.4rem; color: #ff3347; font-size: 1.2rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; }
  .mig-brand h2 { margin: 0; color: #fff; font-size: clamp(4rem, 5vw, 7.6rem); line-height: .96; letter-spacing: -.055em; }
  .mig-brand__heading { display: flex; align-items: end; justify-content: space-between; gap: 4rem; margin-bottom: clamp(4rem, 6vw, 8rem); }
  .mig-brand__intro { max-width: 55rem; color: #929cab; font-size: 1.8rem; line-height: 1.65; }
  .mig-brand__trust { display: grid; grid-template-columns: repeat(4, 1fr); padding-top: 3.2rem; padding-bottom: 3.2rem; border-bottom: 1px solid #20252d; }
  .mig-brand__trust-item { display: flex; gap: 1.6rem; min-height: 8rem; padding: 0 2.8rem; border-left: 1px solid #20252d; }
  .mig-brand__trust-item:first-child { padding-left: 0; border-left: 0; }
  .mig-brand__trust-index { color: #ff3347; font-family: monospace; font-size: 1.1rem; }
  .mig-brand__trust h2 { margin: 0 0 .8rem; font-size: 1.6rem; letter-spacing: .02em; text-transform: uppercase; }
  .mig-brand__trust p { margin: 0; color: #7f8998; font-size: 1.35rem; line-height: 1.45; }
  .mig-brand__products { padding-top: clamp(8rem, 11vw, 15rem); padding-bottom: clamp(9rem, 12vw, 16rem); }
  .mig-brand__product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.6rem; }
  .mig-brand__product-card { overflow: hidden; min-width: 0; border: 1px solid #20252d; border-radius: 1.6rem; background: linear-gradient(145deg, #11151b, #090b0f); transition: transform .35s ease, border-color .35s ease; }
  .mig-brand__product-card:hover { transform: translateY(-.8rem); border-color: #4a525e; }
  .mig-brand__product-link { display: block; color: inherit; text-decoration: none; }
  .mig-brand__product-media { position: relative; overflow: hidden; aspect-ratio: 1 / 1.04; background: radial-gradient(circle at 50% 42%, #263244, #0b0e13 68%); }
  .mig-brand__product-media::after { content: ''; position: absolute; inset: auto 8% 5%; height: 12%; border-radius: 50%; background: #000; filter: blur(2rem); opacity: .7; }
  .mig-brand__product-image { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; padding: 9%; transition: transform .5s ease; }
  .mig-brand__product-card:hover .mig-brand__product-image { transform: scale(1.035); }
  .mig-brand__product-placeholder { display: grid; place-items: center; height: 100%; color: rgba(255,255,255,.08); font-size: 16rem; font-weight: 900; }
  .mig-brand__badge { position: absolute; z-index: 2; top: 1.8rem; left: 1.8rem; padding: .7rem 1rem; border-radius: 100px; color: #fff; background: #d71931; font-size: 1rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
  .mig-brand__product-body { display: grid; grid-template-columns: 1fr auto; padding: 2.4rem; }
  .mig-brand__product-kicker { margin: 0 0 .5rem; color: #7f8998; font-size: 1.1rem; letter-spacing: .14em; text-transform: uppercase; }
  .mig-brand__product-body h3 { margin: 0; color: #fff; font-size: 2.2rem; letter-spacing: -.03em; }
  .mig-brand__arrow { color: #ff3347; font-size: 2.4rem; }
  .mig-brand__product-copy { grid-column: 1 / -1; min-height: 4.6rem; margin: 1.4rem 0 0; color: #8f99a8; font-size: 1.4rem; line-height: 1.55; }
  .mig-brand__price { grid-column: 1 / -1; margin: 1.8rem 0 0; color: #fff; font-size: 1.7rem; font-weight: 700; }
  .mig-brand__process { padding: clamp(9rem, 12vw, 17rem) 0; background: radial-gradient(circle at 72% 10%, rgba(44,93,166,.2), transparent 34%), #0b0e13; }
  .mig-brand__heading--process { border-bottom: 1px solid #29303a; padding-bottom: 5rem; }
  .mig-brand__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.8rem; }
  .mig-brand__step { position: relative; overflow: hidden; min-height: 42rem; padding: 3.2rem; border: 1px solid #29303a; border-radius: 1.6rem; background: linear-gradient(145deg, rgba(255,255,255,.035), transparent); }
  .mig-brand__step-number { color: #ff3347; font-family: monospace; font-size: 1.2rem; }
  .mig-brand__step-visual { position: relative; display: grid; place-items: center; height: 20rem; margin: 2rem 0; }
  .mig-brand__step-visual span { position: absolute; width: 12rem; height: 8rem; border: 1px solid #667487; border-radius: 1.2rem; background: #131922; box-shadow: 0 2rem 5rem rgba(0,0,0,.5); }
  .mig-brand__step-visual span:nth-child(1) { transform: translate(-3rem, 1.5rem) rotate(-12deg); opacity: .38; }
  .mig-brand__step-visual span:nth-child(2) { transform: translate(3rem, -1rem) rotate(9deg); opacity: .62; }
  .mig-brand__step-visual span:nth-child(3) { width: 5.5rem; height: 8.8rem; border-color: #d71931; background: linear-gradient(#ae1025, #24060c); }
  .mig-brand__step h3 { margin: 0; color: #fff; font-size: 2.4rem; }
  .mig-brand__step p { margin: 1.2rem 0 0; color: #8f99a8; font-size: 1.5rem; line-height: 1.6; }
  .mig-brand__comparison { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(5rem, 9vw, 14rem); align-items: center; padding-top: clamp(9rem, 12vw, 17rem); padding-bottom: clamp(9rem, 12vw, 17rem); }
  .mig-brand__comparison-copy .rte { margin: 2.5rem 0 3.2rem; color: #8f99a8; font-size: 1.7rem; line-height: 1.65; }
  .mig-brand__comparison .button--primary { --color-button: 215, 25, 49; --color-button-text: 255, 255, 255; }
  .mig-brand__table { overflow: hidden; border: 1px solid #2a3039; border-radius: 1.6rem; background: #0b0e13; }
  .mig-brand__table-head, .mig-brand__table-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr; align-items: center; min-height: 7.4rem; padding: 0 2.8rem; border-bottom: 1px solid #232933; }
  .mig-brand__table-head { min-height: 5.8rem; color: #788392; font-size: 1.1rem; letter-spacing: .12em; text-transform: uppercase; }
  .mig-brand__table-row:last-child { border-bottom: 0; }
  .mig-brand__table-row span, .mig-brand__table-row strong { font-size: 1.45rem; }
  .mig-brand__table-row strong { color: #fff; }
  .mig-brand__table-row strong::before { content: '●'; margin-right: .8rem; color: #30d58a; }
  .mig-brand__reviews { padding: clamp(9rem, 12vw, 16rem) 0; background: #0b0e13; }
  .mig-brand__rating { margin: 0; color: #ff3347; font-size: 1.6rem; letter-spacing: .2em; }
  .mig-brand__rating span { margin-left: 1rem; color: #8f99a8; font-size: 1.3rem; letter-spacing: 0; }
  .mig-brand__review-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.6rem; }
  .mig-brand__review { margin: 0; padding: 3.2rem; border: 1px solid #29303a; border-radius: 1.6rem; background: #10141a; }
  .mig-brand__stars { color: #ff3347; letter-spacing: .16em; }
  .mig-brand__review > p { min-height: 12rem; margin: 2.2rem 0 3rem; color: #e8edf4; font-size: 1.8rem; line-height: 1.55; }
  .mig-brand__review footer { display: flex; align-items: center; gap: 1.2rem; }
  .mig-brand__avatar { display: grid; place-items: center; width: 4rem; height: 4rem; border-radius: 50%; color: #fff; background: #d71931; font-weight: 700; }
  .mig-brand__review footer strong, .mig-brand__review footer small { display: block; }
  .mig-brand__review footer small { margin-top: .2rem; color: #7f8998; }
  .mig-brand__newsletter { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: end; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(7rem, 9vw, 11rem); }
  .mig-brand__newsletter h2 { font-size: clamp(3.6rem, 4vw, 6rem); }
  .mig-brand__newsletter > div > p:last-child { color: #8f99a8; font-size: 1.6rem; }
  .mig-brand__form { position: relative; display: grid; grid-template-columns: 1fr auto; border-bottom: 1px solid #5c6571; }
  .mig-brand__form input { min-width: 0; padding: 2rem 0; border: 0; color: #fff; background: transparent; font-size: 1.7rem; box-shadow: none; }
  .mig-brand__form input:focus { outline: 0; }
  .mig-brand__form button { padding: 0 2rem; border: 0; color: #fff; background: #d71931; font-weight: 700; cursor: pointer; }
  .mig-brand__form-message { grid-column: 1 / -1; margin: 1rem 0; color: #fff; }
  @media screen and (max-width: 989px) {
    .mig-brand__trust, .mig-brand__product-grid { grid-template-columns: repeat(2, 1fr); }
    .mig-brand__trust-item:nth-child(3) { padding-left: 0; border-left: 0; }
    .mig-brand__trust-item { margin: 1.5rem 0; }
    .mig-brand__heading, .mig-brand__comparison, .mig-brand__newsletter { grid-template-columns: 1fr; }
    .mig-brand__heading { display: grid; align-items: initial; }
    .mig-brand__comparison { gap: 5rem; }
  }
  @media screen and (max-width: 749px) {
    .mig-brand__trust, .mig-brand__product-grid, .mig-brand__steps, .mig-brand__review-grid { grid-template-columns: 1fr; }
    .mig-brand__trust-item, .mig-brand__trust-item:nth-child(3) { padding: 2rem 0; border-left: 0; border-bottom: 1px solid #20252d; }
    .mig-brand__product-media { aspect-ratio: 4 / 3; }
    .mig-brand__table-head, .mig-brand__table-row { grid-template-columns: 1.3fr 1fr .8fr; padding: 0 1.5rem; }
    .mig-brand__review > p { min-height: 0; }
    .mig-brand__form { grid-template-columns: 1fr; border-bottom: 0; }
    .mig-brand__form input { border-bottom: 1px solid #5c6571; }
    .mig-brand__form button { min-height: 5.4rem; }
  }
  @media (prefers-reduced-motion: reduce) { .mig-brand__product-card, .mig-brand__product-image { transition: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "MIG brand homepage",
  "tag": "section",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "trust_label", "label": "Trust section label", "default": "Why customers choose MIG MASTER" },
    { "type": "text", "id": "products_eyebrow", "label": "Products eyebrow", "default": "Built for your library" },
    { "type": "text", "id": "products_heading", "label": "Products heading", "default": "Choose your setup." },
    { "type": "richtext", "id": "products_text", "label": "Products text", "default": "<p>Purpose-built hardware for backing up, organizing, and moving through your personal game collection.</p>" },
    { "type": "text", "id": "process_eyebrow", "label": "Process eyebrow", "default": "Simple by design" },
    { "type": "text", "id": "process_heading", "label": "Process heading", "default": "Three steps. Your whole library." },
    { "type": "richtext", "id": "process_text", "label": "Process text", "default": "<p>No complicated setup. Back up your own cartridges and keep your collection ready when you are.</p>" },
    { "type": "text", "id": "comparison_eyebrow", "label": "Comparison eyebrow", "default": "Why MIG MASTER" },
    { "type": "text", "id": "comparison_heading", "label": "Comparison heading", "default": "Less friction. More playing." },
    { "type": "richtext", "id": "comparison_text", "label": "Comparison text", "default": "<p>A compact, focused system made for players who want control of their physical collection without a desk full of hardware.</p>" },
    { "type": "text", "id": "comparison_button", "label": "Comparison button", "default": "Explore the system" },
    { "type": "url", "id": "comparison_link", "label": "Comparison link" },
    { "type": "text", "id": "table_feature", "label": "Table feature heading", "default": "Experience" },
    { "type": "text", "id": "table_other", "label": "Table alternative heading", "default": "Traditional setup" },
    { "type": "text", "id": "reviews_eyebrow", "label": "Reviews eyebrow", "default": "Player approved" },
    { "type": "text", "id": "reviews_heading", "label": "Reviews heading", "default": "Made for game night." },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 average rating" },
    { "type": "text", "id": "newsletter_eyebrow", "label": "Newsletter eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Updates worth opening." },
    { "type": "text", "id": "newsletter_text", "label": "Newsletter text", "default": "Product releases, firmware news, and member-only offers." },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "Email address" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "Enter your email" },
    { "type": "text", "id": "newsletter_button", "label": "Newsletter button", "default": "Join MIG MASTER" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "You're on the list." }
  ],
  "blocks": [
    { "type": "trust", "name": "Trust point", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "100% focused" },
      { "type": "text", "id": "text", "label": "Text", "default": "Purpose-built for personal game backup workflows." }
    ] },
    { "type": "product", "name": "Product card", "settings": [
      { "type": "product", "id": "product", "label": "Product" },
      { "type": "image_picker", "id": "image", "label": "Fallback image" },
      { "type": "text", "id": "kicker", "label": "Kicker", "default": "Hardware" },
      { "type": "text", "id": "title", "label": "Fallback title", "default": "MIG Flash V2" },
      { "type": "text", "id": "text", "label": "Description", "default": "Compact card-based access to your personal library." },
      { "type": "text", "id": "badge", "label": "Badge" },
      { "type": "url", "id": "link", "label": "Fallback link" }
    ] },
    { "type": "step", "name": "How it works step", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Insert card" },
      { "type": "text", "id": "text", "label": "Text", "default": "Connect your original cartridge to begin your personal backup workflow." }
    ] },
    { "type": "comparison", "name": "Comparison row", "settings": [
      { "type": "text", "id": "title", "label": "Feature", "default": "Portable setup" },
      { "type": "text", "id": "mig_value", "label": "MIG MASTER value", "default": "Compact" },
      { "type": "text", "id": "other_value", "label": "Alternative value", "default": "Bulky" }
    ] },
    { "type": "review", "name": "Review", "settings": [
