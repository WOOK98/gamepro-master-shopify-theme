<div class="section-padding" data-section-type="product-recommendations">
  <div class="container-page">
    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">
        You May Also Like
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto">
        Upgrade your complete gaming setup with these handpicked accessories.
      </p>
    </div>

    {% if product %}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6"
           data-base-url="{{ routes.product_recommendations_url }}?section_id=product-recommendations&product_id={{ product.id }}&limit=4">
        {% if recommendations.products_count > 0 %}
          {% for recommended_product in recommendations.products %}
            {% render 'product-card', product: recommended_product %}
          {% endfor %}
        {% elsif recommendations.performed %}
          <p class="col-span-full text-center text-text-muted py-8">No recommendations available for this product.</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  // Fetch recommendations via AJAX
  (function() {
    var container = document.querySelector('[data-base-url]');
    if (!container) return;
    var url = container.dataset.baseUrl;
    if (!url) return;

    fetch(url)
      .then(function(res) { return res.text(); })
      .then(function(html) {
        var temp = document.createElement('div');
        temp.innerHTML = html;
        var newContent = temp.querySelector('.grid');
        if (newContent) container.innerHTML = newContent.innerHTML;
      })
      .catch(function(err) { console.error('Recommendations fetch failed:', err); });
  })();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "class": "product-recommendations",
  "presets": [
    { "name": "Product Recommendations", "category": "Product" }
  ]
}
{% endschema %}