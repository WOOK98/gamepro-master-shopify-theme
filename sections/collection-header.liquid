<div class="bg-primary-blue border-b border-gray-800" data-section-type="collection-header">
  <div class="container-page py-12 md:py-20">
    <div class="max-w-3xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-text-muted mb-6" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="hover:text-accent-cyan transition-colors">{{ 'general.breadcrumbs.home' | t }}</a>
        <span>/</span>
        {% if collection %}
          <span class="text-accent-cyan">{{ collection.title }}</span>
        {% endif %}
      </nav>

      {% if collection %}
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4">
          {{ collection.title }}
        </h1>

        {% if collection.description != blank %}
          <div class="text-text-secondary text-lg max-w-2xl rte">
            {{ collection.description }}
          </div>
        {% endif %}

        <!-- Filter bar -->
        <div class="flex flex-wrap items-center justify-between gap-4 mt-8 pt-8 border-t border-gray-800">
          <div class="flex flex-wrap gap-2">
            <a class="concept-best-sellers-link" href="{{ collection.url }}?sort_by=best-selling">
              Show best sellers
            </a>
            {% if collection.all_tags.size > 0 %}
              {% for tag in collection.all_tags limit: 6 %}
                <button
                  type="button"
                  class="filter-tag px-4 py-2 rounded-full text-sm border border-gray-700 text-text-secondary hover:border-accent-cyan hover:text-accent-cyan transition-colors"
                  data-tag="{{ tag | handleize }}"
                >
                  {{ tag }}
                </button>
              {% endfor %}
            {% endif %}
          </div>

          <div class="flex items-center gap-2">
            <label for="collection-sort" class="text-sm text-text-muted">{{ 'collections.sorting.title' | t }}</label>
            <select id="collection-sort" class="collection-sort-select bg-primary-blue border border-gray-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:border-accent-cyan cursor-pointer">
              {% for option in collection.sort_options %}
                <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Header",
  "tag": "section",
  "class": "collection-header",
  "presets": [
    { "name": "Collection Header", "category": "Collection" }
  ]
}
{% endschema %}
