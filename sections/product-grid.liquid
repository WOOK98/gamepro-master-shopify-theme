<div class="section-padding" data-section-type="product-grid">
  <div class="container-page">
    <!-- Section header -->
    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">
        {{ section.settings.heading }}
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto">
        {{ section.settings.subheading }}
      </p>
    </div>

    <!-- Quick filter tabs -->
    {% if section.settings.show_filter_tabs %}
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        <button type="button" class="filter-tab active px-5 py-2 rounded-full text-sm font-mono border border-accent-cyan text-accent-cyan bg-accent-cyan/5 transition-colors" data-filter="all">
          All
        </button>
        {% if collection %}
          {% for tag in collection.all_tags limit: 5 %}
            <button type="button" class="filter-tab px-5 py-2 rounded-full text-sm font-mono border border-gray-700 text-text-muted hover:border-accent-cyan hover:text-accent-cyan transition-colors" data-filter="{{ tag | handleize }}">
              {{ tag }}
            </button>
          {% endfor %}
        {% endif %}
      </div>
    {% endif %}

    <!-- Product grid -->
    {% assign selected_collection = collection %}
    {% if section.settings.collection != blank %}
      {% assign selected_collection = collections[section.settings.collection] %}
    {% endif %}

    <div class="product-grid-container grid grid-cols-2 lg:grid-cols-{{ section.settings.columns_desktop }} gap-4 lg:gap-6">
      {% if selected_collection != blank %}
        {% if section.settings.show_all_products %}
          {% paginate selected_collection.products by 250 %}
            {% for product in selected_collection.products %}
              {% render 'product-card',
                product: product,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                show_platforms: section.settings.show_platforms
              %}
            {% else %}
              <div class="concept-empty-state">
                <p>No products found in this collection.</p>
              </div>
            {% endfor %}
          {% endpaginate %}
        {% else %}
          {% for product in selected_collection.products limit: section.settings.products_to_show %}
            {% render 'product-card',
              product: product,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_platforms: section.settings.show_platforms
            %}
          {% else %}
            {% for i in (1..section.settings.products_to_show) %}
              <div class="product-card-placeholder rounded-2xl bg-bg-card aspect-[3/4] flex items-center justify-center">
                <div class="text-center">
                  <div class="w-16 h-16 rounded-full bg-primary-blue/50 flex items-center justify-center mx-auto mb-4">
                    {% render 'icon' with 'package' %}
                  </div>
                  <p class="text-text-muted text-sm">Add products to<br><span class="text-accent-cyan">{{ section.settings.collection | default: 'collection' }}</span></p>
                </div>
              </div>
            {% endfor %}
          {% endfor %}
        {% endif %}
      {% elsif section.settings.show_demo_catalog %}
        {% assign demo_titles = 'Flagship Controller|Wireless Joy-Con Pair|USB-C Accessory Hub|Portable Charging Case|Display Adapter|Controller Travel Case|Pro Gaming Cable' | split: '|' %}
        {% assign demo_prices = '64.99|84.99|54.99|59.99|29.99|39.99|19.99' | split: '|' %}
        {% assign demo_images = 'demo-controller-flagship.png|demo-controller-split-pair.png|demo-controller-dock.png|demo-controller-compact.png|demo-controller-dock.png|demo-controller-flagship.png|demo-controller-compact.png' | split: '|' %}
        {% for demo_title in demo_titles %}
          <article class="concept-scraped-product">
            <div class="concept-scraped-image concept-demo-image">
              <img src="{{ demo_images[forloop.index0] | asset_url }}" alt="{{ demo_title }}" width="900" height="900" loading="lazy">
            </div>
            <div class="concept-scraped-copy">
              <p>DEMO PRODUCT</p>
              <h3>{{ demo_title }}</h3>
              <div>
                <strong>${{ demo_prices[forloop.index0] }}</strong>
                {% render 'icon' with 'arrow-right' %}
              </div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <div class="concept-empty-state">
          <p>Select a collection in the theme editor to show your products.</p>
        </div>
      {% endif %}
    </div>

    <!-- View all link -->
    {% if section.settings.view_all_link and selected_collection and section.settings.show_all_products == false %}
      <div class="text-center mt-12">
        <a href="{{ selected_collection.url }}" class="btn-outline">
          View All {% render 'icon' with 'arrow-right' %}
        </a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .product-grid-container .product-card:nth-child(3n+1) { animation-delay: 0.1s; }
  .product-grid-container .product-card:nth-child(3n+2) { animation-delay: 0.2s; }
  .product-grid-container .product-card:nth-child(3n) { animation-delay: 0.3s; }
</style>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "product-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Connect a Shopify collection to showcase your products."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_demo_catalog",
      "label": "Show generic demo catalog when no collection is selected",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_all_products",
      "label": "Show all products in the selected collection",
      "default": false
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_filter_tabs",
      "label": "Show filter tabs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_platforms",
      "label": "Show platform badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "view_all_link",
      "label": "Show View All button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Grid",
      "category": "Collection",
      "settings": {
        "heading": "Featured Controllers",
        "subheading": "Selected MIG tools, Switch accessories, and setup gear.",
        "products_to_show": 8,
        "columns_desktop": "4"
      }
    }
  ]
}
{% endschema %}
