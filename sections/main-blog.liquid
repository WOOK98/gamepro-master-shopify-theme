<section class="concept-system-page">
  <div class="container-page">
    <h1>{{ blog.title }}</h1>
    <div class="concept-search-results">
      {% for article in blog.articles %}
        <a href="{{ article.url }}">
          {% if article.image %}
            <img src="{{ article.image | image_url: width: 640 }}" alt="{{ article.image.alt | escape }}" width="320" height="240" loading="lazy">
          {% endif %}
          <h2>{{ article.title }}</h2>
          <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{"name":"Main blog","settings":[]}
{% endschema %}
