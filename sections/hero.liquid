{% assign hero_cta_url = section.settings.hero_cta_link | default: routes.all_products_collection_url %}
{% assign hero_overline = section.settings.hero_overline | default: 'MIG FLASH V2 & DUMPER' %}
{% assign hero_title = section.settings.hero_title | default: 'BACKUP. SWITCH. KEEP PLAYING.' %}
{% assign hero_description = section.settings.hero_description | default: 'A clean setup for managing personal Switch game backups with fast card-based switching and fewer moving parts.' %}
{% assign hero_cta = section.settings.hero_cta | default: 'Shop MIG Flash' %}

<section class="concept-hero" data-section-type="hero" data-ps5-hero>
  <div class="concept-hero-shell">
    <div class="concept-hero-topline">
      <span>01</span>
      <span>MIG MASTER</span>
    </div>

    <div class="concept-hero-slider">
      <article class="concept-hero-slide concept-hero-slide--brand is-active" data-hero-slide>
        <img src="{{ 'hero-migmaster-metal-bg.png' | asset_url }}" width="1672" height="941" loading="eager" alt="" class="concept-hero-bg-image" aria-hidden="true">
        <div class="concept-hero-copy">
          <p>MIG FLASH FOR SWITCH</p>
          <h1>{{ hero_title }}</h1>
          <div>{{ hero_description }}</div>
          <a class="concept-hero-cta concept-hero-cta--ghost" href="{{ hero_cta_url }}">
            Explore setup
            <span>&rarr;</span>
          </a>
        </div>
        <div class="concept-hero-mark" aria-hidden="true">
          <span></span>
        </div>
      </article>

      <article class="concept-hero-slide" data-hero-slide>
        <div class="concept-hero-copy">
          <p>{{ hero_overline }}</p>
          <h2>Your entire library.<br>One click away.</h2>
          <ul class="concept-hero-features" aria-label="Hero features">
            <li>{% render 'icon' with 'plug' %} <span>{{ section.settings.hero_feature_1 }}</span></li>
            <li>{% render 'icon' with 'package' %} <span>{{ section.settings.hero_feature_2 }}</span></li>
            <li>{% render 'icon' with 'xp' %} <span>{{ section.settings.hero_feature_3 }}</span></li>
          </ul>
          <a class="concept-hero-cta" href="{{ hero_cta_url }}">
            {{ hero_cta }}
            <span>&rarr;</span>
          </a>
        </div>
        <div class="concept-hero-product" aria-label="MIG Flash V2 and MIG Flash Dumper">
          <div class="concept-hero-product-gallery">
            <figure class="concept-hero-product-card concept-hero-product-card--v2">
              <img src="{{ 'hero-mig-v2-product.jpg' | asset_url }}" width="1254" height="1254" loading="eager" alt="MIG Flash V2 backup cartridge">
              <figcaption>MIG Flash V2</figcaption>
            </figure>
            <figure class="concept-hero-product-card concept-hero-product-card--dumper">
              <img src="{{ 'hero-mig-dumper-product.jpg' | asset_url }}" width="1834" height="1366" loading="eager" alt="MIG Flash Dumper USB-C cartridge reader">
              <figcaption>MIG Flash Dumper</figcaption>
            </figure>
          </div>
        </div>
      </article>

      <article class="concept-hero-slide concept-hero-slide--features" data-hero-slide>
        <div class="concept-hero-copy">
          <p>BUILT FOR SWITCH PLAYERS</p>
          <h2>Backup. Switch.<br>Keep playing.</h2>
          <div>A focused setup for personal game backups, quick card-based switching, and everyday Switch accessories.</div>
        </div>
        <div class="concept-hero-feature-grid">
          <div>
            <strong>Game switching</strong>
            <span>Move between games with a compact card-based setup.</span>
          </div>
          <div>
            <strong>Backup workflow</strong>
            <span>Use Dumper to make cartridge backup more convenient.</span>
          </div>
          <div>
            <strong>Setup support</strong>
            <span>Compatibility notes, setup guidance, and responsive help.</span>
          </div>
        </div>
      </article>
    </div>

    <div class="concept-hero-controls" aria-label="Hero carousel controls">
      <button type="button" data-hero-prev aria-label="Previous hero slide">&larr;</button>
      <div class="concept-hero-progress" aria-hidden="true"><span data-hero-progress></span></div>
      <button type="button" data-hero-next aria-label="Next hero slide">&rarr;</button>
    </div>
  </div>
</section>

<script>
  (() => {
    const heroes = document.querySelectorAll('[data-ps5-hero]');
    heroes.forEach((hero) => {
      const slides = Array.from(hero.querySelectorAll('[data-hero-slide]'));
      const progress = hero.querySelector('[data-hero-progress]');
      const prev = hero.querySelector('[data-hero-prev]');
      const next = hero.querySelector('[data-hero-next]');
      if (slides.length < 2) return;

      let index = 0;
      let timer;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const show = (nextIndex) => {
        index = (nextIndex + slides.length) % slides.length;
        slides.forEach((slide, slideIndex) => {
          slide.classList.toggle('is-active', slideIndex === index);
        });
        if (progress) progress.style.transform = `scaleX(${(index + 1) / slides.length})`;
      };

      const restart = () => {
        window.clearInterval(timer);
        if (!reduceMotion) timer = window.setInterval(() => show(index + 1), 6500);
      };

      prev?.addEventListener('click', () => {
        show(index - 1);
        restart();
      });

      next?.addEventListener('click', () => {
        show(index + 1);
        restart();
      });

      show(0);
      restart();

      hero.addEventListener('mouseenter', () => window.clearInterval(timer));
      hero.addEventListener('mouseleave', restart);
      hero.addEventListener('focusin', () => window.clearInterval(timer));
      hero.addEventListener('focusout', restart);
    });
  })();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_overline",
      "label": "Overline text",
      "default": "MIG FLASH V2 & DUMPER"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "BACKUP. SWITCH. KEEP PLAYING."
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "A clean setup for managing personal Switch game backups with fast card-based switching and fewer moving parts."
    },
    {
      "type": "text",
      "id": "hero_feature_1",
      "label": "Feature 1",
      "default": "Plug & Play"
    },
    {
      "type": "text",
      "id": "hero_feature_2",
      "label": "Feature 2",
      "default": "Easy Backup"
    },
    {
      "type": "text",
      "id": "hero_feature_3",
      "label": "Feature 3",
      "default": "Fast Game Switching"
    },
    {
      "type": "text",
      "id": "hero_cta",
      "label": "CTA button text",
      "default": "Shop MIG Flash"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Hero"
    }
  ]
}
{% endschema %}
