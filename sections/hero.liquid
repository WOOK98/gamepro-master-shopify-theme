<section class="concept-hero" data-section-type="hero">
  <div class="concept-hero-copy">
    <p>{{ section.settings.hero_overline }}</p>
    <h1>{{ section.settings.hero_title }}</h1>
    <div>{{ section.settings.hero_description }}</div>
    <ul class="concept-hero-features" aria-label="Hero features">
      <li>{% render 'icon' with 'plug' %} <span>{{ section.settings.hero_feature_1 }}</span></li>
      <li>{% render 'icon' with 'package' %} <span>{{ section.settings.hero_feature_2 }}</span></li>
      <li>{% render 'icon' with 'xp' %} <span>{{ section.settings.hero_feature_3 }}</span></li>
    </ul>
    <a class="concept-hero-cta" href="{{ section.settings.hero_cta_link | default: routes.all_products_collection_url }}">
      {{ section.settings.hero_cta }}
      <span>&rarr;</span>
    </a>
  </div>
  <div class="concept-hero-product">
    {% assign hero_image_alt = section.settings.hero_title | default: section.settings.hero_overline | default: shop.name %}
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | image_url: width: 1400 }}" width="1400" height="933" loading="eager" alt="{{ hero_image_alt | escape }}" class="concept-hero-product-image">
    {% else %}
      <img src="{{ 'demo-controller-hero.png' | asset_url }}" width="1600" height="800" loading="eager" alt="Original wireless gaming controller" class="concept-hero-product-image">
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_overline",
      "label": "Overline text",
      "default": "MIG FLASH V2 & Dumper"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "YOUR ENTIRE LIBRARY. ONE CLICK AWAY."
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Back up, organize, and switch your game library with a compact plug-and-play setup."
    },
    {
      "type": "text",
      "id": "hero_feature_1",
      "label": "Feature 1",
      "default": "Plug & Play"
    },
    {
      "type": "text",
      "id": "hero_feature_2",
      "label": "Feature 2",
      "default": "Easy Backup"
    },
    {
      "type": "text",
      "id": "hero_feature_3",
      "label": "Feature 3",
      "default": "Fast Game Switching"
    },
    {
      "type": "text",
      "id": "hero_cta",
      "label": "CTA button text",
      "default": "Shop MIG Flash"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Hero"
    }
  ]
}
{% endschema %}
