<section class="concept-system-page">
  {% unless page.handle == 'gamedirectory' %}
    <div class="container-page concept-prose">
      <h1>{{ page.title | default: 'Contact' }}</h1>
      {{ page.content }}
      {% form 'contact', class: 'concept-contact-form' %}
        {% if form.posted_successfully? %}<p>{{ 'contact.success' | t }}</p>{% endif %}
        {{ form.errors | default_errors }}
        <label>{{ 'contact.name' | t }}<input type="text" name="contact[name]" value="{{ form.name }}"></label>
        <label>{{ 'contact.email' | t }}<input type="email" name="contact[email]" value="{{ form.email }}" required></label>
        <label>{{ 'contact.phone' | t }}<input type="tel" name="contact[phone]" value="{{ form.phone }}"></label>
        <label>{{ 'contact.message' | t }}<textarea name="contact[body]" rows="7" required>{{ form.body }}</textarea></label>
        <button class="btn-primary" type="submit">{{ 'contact.send' | t }}</button>
      {% endform %}
    </div>
  {% endunless %}
</section>

{% schema %}
{"name":"Main contact","settings":[]}
{% endschema %}
