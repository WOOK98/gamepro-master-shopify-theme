<section class="concept-system-page">
  <div class="container-page">
    <h1>{{ 'collections.title' | t }}</h1>
    <div class="concept-search-results">
      {% for collection in collections %}
        <a href="{{ collection.url }}">
          {% if collection.featured_image %}
            <img src="{{ collection.featured_image | image_url: width: 640 }}" alt="{{ collection.featured_image.alt | escape }}" width="320" height="320" loading="lazy">
          {% endif %}
          <h2>{{ collection.title }}</h2>
          <p>{{ collection.products_count }} {{ 'collections.products' | t }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{"name":"Main collections","settings":[]}
{% endschema %}
