<footer class="concept-footer">
  <div class="container-page">
    <div class="concept-footer-top">
      <div class="concept-footer-newsletter">
        <h4>{{ 'layout.footer.newsletter_title' | t }}</h4>
        <p>{{ 'layout.footer.newsletter_desc' | t }}</p>
        {% form 'customer', class: 'concept-footer-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="sr-only" for="FooterNewsletterEmail">{{ 'sections.newsletter.placeholder' | t }}</label>
          <input
            id="FooterNewsletterEmail"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ 'sections.newsletter.placeholder' | t }}"
            autocomplete="email"
            required
          >
          <button type="submit" aria-label="{{ 'sections.newsletter.button' | t }}">&rarr;</button>

          {% if form.posted_successfully? %}
            <p class="concept-footer-message">{{ 'sections.newsletter.success_text' | t }}</p>
          {% endif %}

          {% if form.errors %}
            <div class="concept-footer-message concept-footer-error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}
        {% endform %}
      </div>

      <div class="concept-footer-social">
        {% if settings.social_twitter != blank %}
          <a href="{{ settings.social_twitter }}" aria-label="X" target="_blank" rel="noopener">X</a>
        {% endif %}
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">◎</a>
        {% endif %}
        {% if settings.social_youtube != blank %}
          <a href="{{ settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">▶</a>
        {% endif %}
      </div>
    </div>

    <div class="concept-footer-middle">
      {% if localization.available_countries.size > 1 %}
        <div class="concept-footer-localization">
          <p>{{ 'layout.footer.country_region' | t }}</p>
          {% form 'localization', id: 'FooterLocalizationForm', class: 'concept-footer-localization-form' %}
            <label class="sr-only" for="FooterCountrySelector">{{ 'layout.footer.country_region' | t }}</label>
            <select id="FooterCountrySelector" name="country_code" onchange="this.form.submit()">
              {% for country in localization.available_countries %}
                <option
                  value="{{ country.iso_code }}"
                  {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                >
                  {{ country.name }} | {{ country.currency.iso_code }} {{ country.currency.symbol }}
                </option>
              {% endfor %}
            </select>
          {% endform %}
        </div>
      {% elsif localization.country %}
        <div class="concept-footer-localization">
          <p>{{ 'layout.footer.country_region' | t }}</p>
          <div class="concept-footer-localization-static">
            {{ localization.country.name }} | {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}
          </div>
        </div>
      {% endif %}

      {% if settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
        <div class="concept-footer-payments" aria-label="{{ 'layout.footer.payment_methods' | t }}">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'concept-footer-payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="concept-footer-bottom">
      {% assign current_year = 'now' | date: '%Y' %}
      <p>{{ 'layout.footer.copyright' | t: year: current_year, shop_name: shop.name }}</p>
      <nav class="concept-footer-policies" aria-label="{{ 'layout.footer.policies' | t }}">
        {% if shop.privacy_policy.url %}
          <a href="{{ shop.privacy_policy.url }}">{{ 'layout.footer.privacy' | t }}</a>
        {% endif %}
        {% if shop.refund_policy.url %}
          <a href="{{ shop.refund_policy.url }}">{{ 'layout.footer.refund_policy' | t }}</a>
        {% endif %}
        {% if shop.terms_of_service.url %}
          <a href="{{ shop.terms_of_service.url }}">{{ 'layout.footer.terms' | t }}</a>
        {% endif %}
        {% if pages.contact.url %}
          <a href="{{ pages.contact.url }}">{{ 'layout.footer.contact_information' | t }}</a>
        {% endif %}
        {% if shop.shipping_policy.url %}
          <a href="{{ shop.shipping_policy.url }}">{{ 'layout.footer.shipping_policy' | t }}</a>
        {% endif %}
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
