<footer class="concept-footer" data-hide-social-rail>
  <div class="container-page">
    <div class="concept-footer-middle">
      {% if localization.available_countries.size > 1 %}
        <div class="concept-footer-localization">
          <p>{{ 'layout.footer.country_region' | t }}</p>
          {% form 'localization', id: 'FooterLocalizationForm', class: 'concept-footer-localization-form' %}
            <label class="sr-only" for="FooterCountrySelector">{{ 'layout.footer.country_region' | t }}</label>
            <select id="FooterCountrySelector" name="country_code" onchange="this.form.submit()">
              {% for country in localization.available_countries %}
                <option
                  value="{{ country.iso_code }}"
                  {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                >
                  {{ country.name }} | {{ country.currency.iso_code }} {{ country.currency.symbol }}
                </option>
              {% endfor %}
            </select>
          {% endform %}
        </div>
      {% elsif localization.country %}
        <div class="concept-footer-localization">
          <p>{{ 'layout.footer.country_region' | t }}</p>
          <div class="concept-footer-localization-static">
            {{ localization.country.name }} | {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}
          </div>
        </div>
      {% endif %}

      {% if settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
        <div class="concept-footer-payments" aria-label="{{ 'layout.footer.payment_methods' | t }}">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'concept-footer-payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="concept-footer-bottom">
      {% assign current_year = 'now' | date: '%Y' %}
      <p>{{ 'layout.footer.copyright' | t: year: current_year, shop_name: shop.name }}</p>
      <nav class="concept-footer-policies" aria-label="{{ 'layout.footer.policies' | t }}">
        {% if shop.privacy_policy.url %}
          <a href="{{ shop.privacy_policy.url }}">{{ 'layout.footer.privacy' | t }}</a>
        {% endif %}
        {% if shop.refund_policy.url %}
          <a href="{{ shop.refund_policy.url }}">{{ 'layout.footer.refund_policy' | t }}</a>
        {% endif %}
        {% if shop.terms_of_service.url %}
          <a href="{{ shop.terms_of_service.url }}">{{ 'layout.footer.terms' | t }}</a>
        {% endif %}
        {% if pages.contact.url %}
          <a href="{{ pages.contact.url }}">{{ 'layout.footer.contact_information' | t }}</a>
        {% endif %}
        {% if shop.shipping_policy.url %}
          <a href="{{ shop.shipping_policy.url }}">{{ 'layout.footer.shipping_policy' | t }}</a>
        {% endif %}
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
