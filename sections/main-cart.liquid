<section class="concept-system-page">
  <div class="container-page">
    <h1>{{ 'cart.title' | t }}</h1>
    {% if cart.item_count == 0 %}
      <p>{{ 'cart.empty' | t }}</p>
      <a class="btn-primary" href="{{ routes.all_products_collection_url }}">{{ 'cart.continue_shopping' | t }}</a>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="concept-cart-list">
          {% for item in cart.items %}
            <article class="concept-cart-item">
              <a href="{{ item.url }}">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.image.alt | escape }}" width="120" height="120" loading="lazy">
                {% endif %}
              </a>
              <div>
                <h2><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                {% unless item.product.has_only_default_variant %}<p>{{ item.variant.title }}</p>{% endunless %}
                <strong>{{ item.final_line_price | money }}</strong>
              </div>
              <label>
                <span class="sr-only">{{ 'cart.quantity' | t }}</span>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </label>
              <a href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
            </article>
          {% endfor %}
        </div>
        <div class="concept-cart-summary">
          <p>{{ 'cart.subtotal' | t }} <strong>{{ cart.total_price | money }}</strong></p>
          {% if cart.taxes_included %}<small>{{ 'cart.taxes_included' | t }}</small>{% endif %}
          <div>
            <button class="btn-outline" type="submit" name="update">{{ 'cart.update' | t }}</button>
            <button class="btn-primary" type="submit" name="checkout">{{ 'cart.checkout' | t }}</button>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{"name":"Main cart","settings":[]}
{% endschema %}
