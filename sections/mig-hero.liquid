<section class="mig-hero" aria-labelledby="MigHeroTitle-{{ section.id }}">
  <div class="visually-hidden">
    <p>{{ section.settings.eyebrow | escape }}</p>
    <h1 id="MigHeroTitle-{{ section.id }}">{{ section.settings.heading | escape }}</h1>
    <div>{{ section.settings.text | strip_html | escape }}</div>
    <ul>
      {%- for block in section.blocks -%}
        <li>{{ block.settings.text | escape }}</li>
      {%- endfor -%}
    </ul>
  </div>

  <div class="mig-hero__desktop">
    <img
      class="mig-hero__desktop-image"
      src="{{ 'mig-home-hero.webp' | asset_url }}"
      alt=""
      width="2032"
      height="1008"
      loading="eager"
      fetchpriority="high"
    >

    {%- if section.settings.primary_label != blank -%}
      <a
        class="mig-hero__hotspot mig-hero__hotspot--primary"
        href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}"
        aria-label="{{ section.settings.primary_label | escape }}"
      ></a>
    {%- endif -%}
    {%- if section.settings.secondary_label != blank -%}
      <a
        class="mig-hero__hotspot mig-hero__hotspot--secondary"
        href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}"
        aria-label="{{ section.settings.secondary_label | escape }}"
      ></a>
    {%- endif -%}
  </div>

  <div class="mig-hero__mobile page-width">
    <div class="mig-hero__mobile-copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="mig-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <div class="mig-hero__title" aria-hidden="true">{{ section.settings.heading | escape }}</div>
      {%- if section.settings.text != blank -%}
        <div class="mig-hero__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      <ul class="mig-hero__features" aria-label="Product highlights">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <span aria-hidden="true"></span>
            {{ block.settings.text | escape }}
          </li>
        {%- endfor -%}
      </ul>

      <div class="mig-hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="button button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="button button--secondary" href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.image != blank -%}
      <div class="mig-hero__mobile-media">
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag:
            widths: '480, 750, 1000',
            sizes: '100vw',
            loading: 'eager',
            class: 'mig-hero__mobile-image',
            alt: section.settings.image.alt
        }}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mig-hero {
    position: relative;
    overflow: hidden;
    color: #f7f8fb;
    background: #05070a;
  }

  .mig-hero__desktop {
    position: relative;
    width: 100%;
    aspect-ratio: 2032 / 1008;
    background: #05070a;
  }

  .mig-hero__desktop-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mig-hero__hotspot {
    position: absolute;
    z-index: 2;
    top: 74.2%;
    height: 8.2%;
    border-radius: 0.8rem;
  }

  .mig-hero__hotspot--primary {
    left: 3%;
    width: 15.8%;
  }

  .mig-hero__hotspot--secondary {
    left: 20%;
    width: 15.2%;
  }

  .mig-hero__hotspot:focus-visible {
    outline: 0.3rem solid #fff;
    outline-offset: 0.3rem;
  }

  .mig-hero__mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .mig-hero__desktop {
      display: none;
    }

    .mig-hero__mobile {
      display: grid;
      gap: 3.2rem;
      padding-top: 4.8rem;
      padding-bottom: 4.8rem;
      background:
        radial-gradient(circle at 72% 78%, rgba(84, 141, 225, 0.2), transparent 40%),
        #05070a;
    }

    .mig-hero__eyebrow {
      margin: 0 0 1.4rem;
      color: #e31c2b;
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .mig-hero__title {
      max-width: 9ch;
      margin: 0;
      color: #f7f8fb;
      font-size: clamp(4.8rem, 15vw, 6.8rem);
      font-weight: 850;
      letter-spacing: -0.06em;
      line-height: 0.9;
    }

    .mig-hero__text {
      margin-top: 2.2rem;
      color: rgba(237, 240, 246, 0.68);
      font-size: 1.6rem;
      line-height: 1.55;
    }

    .mig-hero__features {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.4rem;
      margin: 2.6rem 0 0;
      padding: 0;
      list-style: none;
    }

    .mig-hero__features li {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: rgba(247, 248, 251, 0.84);
      font-size: 1.2rem;
      line-height: 1.35;
    }

    .mig-hero__features li > span {
      width: 0.7rem;
      height: 0.7rem;
      flex: 0 0 0.7rem;
      border-radius: 50%;
      background: #e31c2b;
    }

    .mig-hero__actions {
      display: grid;
      gap: 1.2rem;
      margin-top: 3rem;
    }

    .mig-hero .button--primary {
      --color-button: 227, 28, 43;
      --color-button-text: 255, 255, 255;
    }

    .mig-hero .button--secondary {
      --color-button: 247, 248, 251;
      --color-button-text: 247, 248, 251;
      color: #f7f8fb;
      background: transparent;
    }

    .mig-hero__mobile-media {
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 2rem;
      background: #090d14;
    }

    .mig-hero__mobile-image {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      object-position: 68% center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MIG hero",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MIG Flash for Switch"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "BACK UP. SWITCH. KEEP PLAYING."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Manage personal Switch game backups with a compact card-based setup designed for simpler switching.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Mobile product image"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop MIG Flash V2"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View MIG Dumper"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Plug & play"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MIG hero",
      "blocks": [
        { "type": "feature", "settings": { "text": "Plug & play" } },
        { "type": "feature", "settings": { "text": "Easy backup" } },
        { "type": "feature", "settings": { "text": "Fast game switching" } }
      ]
    }
  ]
}
{% endschema %}
