{%- liquid
  assign hero_heading = section.settings.heading | default: 'BACK UP. SWITCH. KEEP PLAYING.'
  assign heading_lines = hero_heading | newline_to_br | split: '<br />'
-%}

<section
  id="MigHero-{{ section.id }}"
  class="mig-hero"
  aria-labelledby="MigHeroTitle-{{ section.id }}"
  style="--mig-hero-accent: {{ section.settings.accent_color }};"
>
  <div class="mig-hero__ambient" aria-hidden="true"></div>
  <div class="mig-hero__layout page-width">
    <div class="mig-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="mig-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h1 id="MigHeroTitle-{{ section.id }}" class="mig-hero__title">
        {%- for line in heading_lines -%}
          {%- liquid
            assign clean_line = line | strip
            assign final_character = clean_line | slice: -1, 1
            assign visible_line = clean_line
            if final_character == '.'
              assign visible_length = clean_line.size | minus: 1
              assign visible_line = clean_line | slice: 0, visible_length
            endif
          -%}
          <span class="mig-hero__title-line">
            {{- visible_line | escape -}}
            {%- if final_character == '.' -%}<span class="mig-hero__title-dot" aria-hidden="true">.</span>{%- endif -%}
          </span>
        {%- endfor -%}
      </h1>

      {%- if section.settings.text != blank -%}
        <div class="mig-hero__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="mig-hero__features" aria-label="{{ section.settings.features_label | escape }}">
          {%- for block in section.blocks -%}
            <li class="mig-hero__feature" {{ block.shopify_attributes }}>
              <span class="mig-hero__feature-icon" aria-hidden="true">
                {% render 'mig-icon', icon: block.settings.icon %}
              </span>
              <span>{{ block.settings.text | escape }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="mig-hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="mig-hero__button mig-hero__button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            <span>{{ section.settings.primary_label | escape }}</span>
            <span aria-hidden="true">→</span>
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="mig-hero__button mig-hero__button--secondary" href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}">
            <span>{{ section.settings.secondary_label | escape }}</span>
            <span aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="mig-hero__media">
      <div class="mig-hero__media-glow" aria-hidden="true"></div>
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 2200
          | image_tag:
            widths: '640, 900, 1200, 1600, 2000, 2200',
            sizes: '(min-width: 1200px) 56vw, (min-width: 990px) 52vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'mig-hero__image',
            alt: section.settings.image.alt
        }}
      {%- else -%}
        <div class="mig-hero__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mig-hero,
  .mig-hero *,
  .mig-hero *::before,
  .mig-hero *::after {
    box-sizing: border-box;
  }

  .mig-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #f7f8fb;
    background:
      radial-gradient(circle at 82% 12%, rgba(73, 116, 183, 0.25), transparent 35%),
      linear-gradient(108deg, #040506 0%, #070a10 48%, #0d1726 100%);
  }

  .mig-hero__ambient {
    position: absolute;
    z-index: -1;
    inset: 0;
    opacity: 0.4;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 4.8rem 4.8rem;
    mask-image: linear-gradient(90deg, #000, transparent 72%);
    pointer-events: none;
  }

  .mig-hero__layout {
    display: grid;
    grid-template-columns: minmax(34rem, 0.82fr) minmax(0, 1.18fr);
    align-items: center;
    gap: clamp(3.2rem, 5vw, 8rem);
    min-height: clamp(64rem, calc(100svh - 12rem), 86rem);
    padding-top: clamp(5.6rem, 7vw, 9.6rem);
    padding-bottom: clamp(5.6rem, 7vw, 9.6rem);
  }

  .mig-hero__copy {
    position: relative;
    z-index: 3;
    min-width: 0;
  }

  .mig-hero__eyebrow {
    margin: 0 0 1.8rem;
    color: var(--mig-hero-accent, #e31c2b);
    font-size: 1.25rem;
    font-weight: 750;
    letter-spacing: 0.2em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .mig-hero__title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 8.8ch;
    margin: 0;
    color: #f7f8fb;
    font-size: clamp(5.4rem, 6.5vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.065em;
    line-height: 0.88;
    text-wrap: balance;
  }

  .mig-hero__title-line {
    display: block;
  }

  .mig-hero__title-dot {
    color: var(--mig-hero-accent, #e31c2b);
  }

  .mig-hero__text {
    max-width: 50rem;
    margin-top: 2.8rem;
    color: rgba(231, 235, 242, 0.68);
    font-size: clamp(1.55rem, 1.3vw, 1.9rem);
    line-height: 1.55;
  }

  .mig-hero__text > * {
    margin-top: 0;
    margin-bottom: 0;
  }

  .mig-hero__features {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem clamp(1.8rem, 2.5vw, 3.4rem);
    margin: 3.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .mig-hero__feature {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: rgba(243, 246, 251, 0.82);
    font-size: 1.25rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .mig-hero__feature-icon {
    display: grid;
    place-items: center;
    width: 3.4rem;
    height: 3.4rem;
    flex: 0 0 3.4rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: #f7f8fb;
    background: rgba(255, 255, 255, 0.025);
  }

  .mig-hero__feature-icon svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  .mig-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 3.8rem;
  }

  .mig-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
    min-height: 5.6rem;
    padding: 1.4rem 2.6rem;
    border: 1px solid transparent;
    border-radius: 0.6rem;
    color: #fff;
    font-size: 1.45rem;
    font-weight: 750;
    line-height: 1.2;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
  }

  .mig-hero__button:hover {
    transform: translateY(-0.2rem);
  }

  .mig-hero__button:focus-visible {
    outline: 0.2rem solid #fff;
    outline-offset: 0.3rem;
  }

  .mig-hero__button--primary {
    border-color: var(--mig-hero-accent, #e31c2b);
    background: var(--mig-hero-accent, #e31c2b);
  }

  .mig-hero__button--primary:hover {
    border-color: #ff3347;
    background: #ff3347;
  }

  .mig-hero__button--secondary {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.025);
  }

  .mig-hero__button--secondary:hover {
    border-color: rgba(255, 255, 255, 0.82);
    background: rgba(255, 255, 255, 0.08);
  }

  .mig-hero__media {
    position: relative;
    min-width: 0;
    min-height: clamp(44rem, 48vw, 70rem);
    align-self: stretch;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: clamp(1.8rem, 3vw, 4rem);
    background: rgba(3, 6, 11, 0.55);
    box-shadow: 0 4rem 12rem rgba(0, 0, 0, 0.45);
  }

  .mig-hero__media-glow {
    position: absolute;
    z-index: 0;
    inset: -18%;
    background: radial-gradient(circle at 64% 42%, rgba(100, 162, 255, 0.27), transparent 54%);
    pointer-events: none;
  }

  .mig-hero__image,
  .mig-hero__placeholder {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .mig-hero__image {
    object-fit: cover;
    object-position: 68% center;
  }

  .mig-hero__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: rgba(255, 255, 255, 0.08);
  }

  @media screen and (min-width: 1400px) {
    .mig-hero__layout {
      max-width: 176rem;
    }
  }

  @media screen and (max-width: 989px) {
    .mig-hero__layout {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 3.6rem;
      padding-top: 4.8rem;
      padding-bottom: 4.8rem;
    }

    .mig-hero__title {
      max-width: 10ch;
      font-size: clamp(5rem, 13vw, 8rem);
    }

    .mig-hero__media {
      min-height: clamp(34rem, 78vw, 58rem);
    }
  }

  @media screen and (max-width: 749px) {
    .mig-hero__layout {
      gap: 3rem;
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .mig-hero__title {
      max-width: 9.5ch;
      font-size: clamp(4.4rem, 14.5vw, 6.8rem);
    }

    .mig-hero__features {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.4rem;
    }

    .mig-hero__feature {
      font-size: 1.1rem;
    }

    .mig-hero__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .mig-hero__button {
      width: 100%;
    }

    .mig-hero__media {
      min-height: min(88vw, 48rem);
      border-radius: 2rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .mig-hero__copy {
      animation: mig-hero-copy-in 700ms ease-out both;
    }

    .mig-hero__image {
      animation: mig-hero-image-in 900ms ease-out both;
    }

    @keyframes mig-hero-copy-in {
      from { opacity: 0; transform: translateY(1.6rem); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes mig-hero-image-in {
      from { opacity: 0; transform: scale(1.025); }
      to { opacity: 1; transform: scale(1); }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mig-hero__button {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MIG hero",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MIG Flash for Switch"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Add a line break after each short statement.",
      "default": "BACK UP.\nSWITCH.\nKEEP PLAYING."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Manage personal Switch game backups with a compact card-based setup designed for simpler switching.</p>"
    },
    {
      "type": "text",
      "id": "features_label",
      "label": "Feature list accessibility label",
      "default": "Product highlights"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Use a wide product image with the product positioned toward the right."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop MIG Flash V2"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View MIG Dumper"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#e31c2b"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "plug", "label": "Plug" },
            { "value": "box", "label": "Box" },
            { "value": "zap", "label": "Lightning" },
            { "value": "shield", "label": "Shield" },
            { "value": "database", "label": "Storage" },
            { "value": "gamepad", "label": "Game controller" }
          ],
          "default": "plug"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Plug & play"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MIG hero",
      "blocks": [
        { "type": "feature", "settings": { "icon": "plug", "text": "Plug & play" } },
        { "type": "feature", "settings": { "icon": "box", "text": "Easy backup" } },
        { "type": "feature", "settings": { "icon": "zap", "text": "Fast game switching" } }
      ]
    }
  ]
}
{% endschema %}
