<div class="section-padding" data-section-type="product-main" data-product-main-section>
  <div class="container-page">
    {% if product %}
    {% assign product_display_title = product.metafields.custom.short_title.value | default: product.title %}
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign product_sales_count = product.metafields.custom.sales_count.value | default: settings.default_sales_count %}
    <div class="product-layout">
      <!-- Product images gallery -->
      <div class="product-gallery">
        <div class="product-main-image">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 1600 }}"
              srcset="
                {{ product.featured_image | image_url: width: 800 }} 800w,
                {{ product.featured_image | image_url: width: 1200 }} 1200w,
                {{ product.featured_image | image_url: width: 1600 }} 1600w
              "
              sizes="(min-width: 990px) 58vw, 100vw"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="eager"
              class="product-main-image-media"
              id="product-main-image"
            >
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="product-thumbnails grid grid-cols-4 gap-3">
            {% for image in product.images %}
              <button
                type="button"
                class="product-thumb {% if forloop.first %}is-active{% endif %}"
                data-image-src="{{ image | image_url: width: 1600 }}"
                data-image-srcset="{{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
                data-image-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="View product image {{ forloop.index }}"
              >
                <img src="{{ image | image_url: width: 320 }}" alt="{{ image.alt | default: product.title | escape }}" width="320" height="320" loading="lazy">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product info -->
      <div class="product-info">
        {% if product.vendor %}
          <p class="text-text-muted text-xs uppercase tracking-widest mb-2">{{ product.vendor }}</p>
        {% endif %}

        <h1>
          {{ product_display_title }}
        </h1>

        <!-- Rating -->
        {% if product.metafields.reviews.rating.value %}
          <div class="flex items-center gap-2 mb-6">
            {% render 'rating-stars', rating: product.metafields.reviews.rating.value %}
            <span class="text-text-muted text-sm">({{ product.metafields.reviews.rating_count.value }} reviews)</span>
          </div>
        {% endif %}

        <!-- Price -->
        <div class="product-price-block">
          {% render 'price', product: product %}
          {% if settings.show_sales_count and product_sales_count != blank %}
            <p class="concept-sales-count concept-sales-count--product">
              <span>Best seller</span>
              {{ product_sales_count }} sold
            </p>
          {% endif %}
        </div>

        <!-- Variant selectors -->
        {% unless product.has_only_default_variant %}
          <div class="product-options" data-product-options>
            {% for option in product.options_with_values %}
            <div class="product-option-group" data-option-position="{{ option.position }}">
              <label class="product-option-label">
                {{ option.name }}: <span data-selected-option-label>{{ option.selected_value }}</span>
              </label>
              <div class="product-option-values">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="product-option-button {% if value == option.selected_value %}is-active{% endif %}"
                    data-option-value="{{ value | escape }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </div>
        {% endunless %}

        <!-- Add to cart -->
        {% form 'product', product, id: 'ProductForm', class: 'product-form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-input>
          <div class="product-quantity">
            <button type="button" class="qty-btn" data-action="decrease" aria-label="Decrease quantity">-</button>
            <input type="number" name="quantity" value="1" min="1" class="qty-input" readonly>
            <button type="button" class="qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
          </div>

          <button
            type="submit"
            class="btn-primary add-to-cart-btn"
            data-add-to-cart
            data-add-text="{{ 'products.product.add_to_cart' | t }}"
            data-sold-out-text="{{ 'products.product.sold_out' | t }}"
            data-variant-id="{{ current_variant.id }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}
              {% render 'icon' with 'shopping-cart' %}
              {{ 'products.product.add_to_cart' | t }}
            {% else %}
              {{ 'products.product.sold_out' | t }}
            {% endif %}
          </button>
        {% endform %}

        <!-- Product accordion (tech specs) -->
        <div class="product-accordions mt-8 space-y-3">
          {% if product.description != blank %}
            <details class="product-accordion bg-bg-card rounded-xl">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
                <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">{{ 'products.product.description' | t }}</span>
                <span class="accordion-icon text-accent-cyan">+</span>
              </summary>
              <div class="px-6 pb-6 text-text-secondary rte">
                {{ product.description }}
              </div>
            </details>
          {% endif %}

          {% if product.metafields.custom.tech_specs %}
            <details class="product-accordion bg-bg-card rounded-xl">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
                <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">Tech Specs</span>
                <span class="accordion-icon text-accent-cyan">+</span>
              </summary>
              <div class="px-6 pb-6">
                <table class="w-full text-sm">
                  {% for spec in product.metafields.custom.tech_specs.value %}
                    <tr class="border-b border-gray-800 last:border-0">
                      <td class="py-3 text-text-muted font-mono uppercase tracking-wider text-xs">{{ spec[0] }}</td>
                      <td class="py-3 text-white font-mono text-right">{{ spec[1] }}</td>
                    </tr>
                  {% endfor %}
                </table>
              </div>
            </details>
          {% endif %}

          <details class="product-accordion bg-bg-card rounded-xl">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
              <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">Shipping & Returns</span>
              <span class="accordion-icon text-accent-cyan">+</span>
            </summary>
            <div class="px-6 pb-6 text-text-secondary text-sm space-y-2">
              <p>Free standard shipping on orders over $50.</p>
              <p>Express shipping available at checkout.</p>
              <p>30-day hassle-free return policy.</p>
            </div>
          </details>
        </div>

        <!-- Compatibility badges -->
        <div class="flex flex-wrap gap-3 mt-8 pt-6 border-t border-gray-800">
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'monitor' %} PC
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} Xbox Series X|S
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} PS5
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} Switch
          </span>
        </div>
      </div>
    </div>
    <script type="application/json" data-product-variants>
      {{ product.variants | json }}
    </script>
    {% endif %}
  </div>
</div>

<style>
  .product-accordion summary {
    list-style: none;
  }
  .product-accordion summary::-webkit-details-marker { display: none; }
  .product-accordion[open] .accordion-icon {
    transform: rotate(45deg);
  }
  .accordion-icon { transition: transform 0.3s; font-size: 1.2rem; }
</style>

<script>
(function() {
  var section = document.querySelector('[data-product-main-section]');
  if (!section) return;
  var variantsNode = section.querySelector('[data-product-variants]');
  var variants = [];
  try {
    variants = variantsNode ? JSON.parse(variantsNode.textContent) : [];
  } catch (error) {
    variants = [];
  }
  var optionGroups = Array.prototype.slice.call(section.querySelectorAll('.product-option-group'));
  var selectedOptions = optionGroups.map(function(group) {
    var active = group.querySelector('.product-option-button.is-active');
    return active ? active.getAttribute('data-option-value') : '';
  });
  var variantInput = section.querySelector('[data-variant-input]');
  var addBtn = section.querySelector('[data-add-to-cart]');
  var mainImg = section.querySelector('#product-main-image');

  function findVariant() {
    return variants.find(function(variant) {
      return selectedOptions.every(function(value, index) {
        return variant.options[index] === value;
      });
    });
  }

  function imageFromVariant(variant) {
    if (!variant || !variant.featured_image) return null;
    return variant.featured_image.src || variant.featured_image.url || null;
  }

  function setButtonContent(button, text) {
    if (!button) return;
    button.innerHTML = text;
  }

  function updateVariant() {
    var variant = findVariant();
    if (!variant) {
      if (addBtn) {
        addBtn.disabled = true;
        setButtonContent(addBtn, addBtn.getAttribute('data-sold-out-text') || 'Sold out');
      }
      return;
    }

    if (variantInput) variantInput.value = variant.id;
    if (addBtn) {
      addBtn.dataset.variantId = variant.id;
      addBtn.disabled = !variant.available;
      if (variant.available) {
        setButtonContent(addBtn, addBtn.getAttribute('data-add-text') || 'Add to Cart');
      } else {
        setButtonContent(addBtn, addBtn.getAttribute('data-sold-out-text') || 'Sold out');
      }
    }

    var variantImage = imageFromVariant(variant);
    if (mainImg && variantImage) {
      mainImg.src = variantImage;
      mainImg.removeAttribute('srcset');
    }
  }

  // Thumbnail switcher
  section.querySelectorAll('.product-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var src = btn.getAttribute('data-image-src');
      var srcset = btn.getAttribute('data-image-srcset');
      var alt = btn.getAttribute('data-image-alt');
      if (mainImg && src) {
        mainImg.src = src;
        if (srcset) mainImg.srcset = srcset;
        if (alt) mainImg.alt = alt;
      }

      section.querySelectorAll('.product-thumb').forEach(function(t) {
        t.classList.remove('is-active');
      });
      btn.classList.add('is-active');
    });
  });

  // Variant selector
  optionGroups.forEach(function(group, groupIndex) {
    var label = group.querySelector('[data-selected-option-label]');
    group.querySelectorAll('.product-option-button').forEach(function(button) {
      button.addEventListener('click', function() {
        selectedOptions[groupIndex] = button.getAttribute('data-option-value');
        group.querySelectorAll('.product-option-button').forEach(function(item) {
          item.classList.remove('is-active');
        });
        button.classList.add('is-active');
        if (label) label.textContent = selectedOptions[groupIndex];
        updateVariant();
      });
    });
  });

  // Quantity selector
  var qtyInput = section.querySelector('.qty-input');
  section.querySelectorAll('.qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value) || 1;
      if (btn.dataset.action === 'increase') qtyInput.value = val + 1;
      else if (btn.dataset.action === 'decrease' && val > 1) qtyInput.value = val - 1;
    });
  });

  // Add to cart
  if (addBtn) {
    addBtn.addEventListener('click', function(event) {
      event.preventDefault();
      var variantId = variantInput?.value || addBtn.dataset.variantId;
      var qty = parseInt(qtyInput?.value || 1);
      if (!variantId) return;

      addBtn.classList.add('loading');
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        addBtn.classList.remove('loading');
        addBtn.innerHTML = '&#10003; Added to Cart';
        setTimeout(function() { addBtn.innerHTML = addBtn.dataset.originalText || 'Add to Cart'; }, 2000);
        document.dispatchEvent(new CustomEvent('cart:updated'));
      })
      .catch(function(err) {
        console.error(err);
        addBtn.classList.remove('loading');
      });
    });
    addBtn.dataset.originalText = addBtn.innerHTML;
  }

  updateVariant();
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "class": "product-main",
  "presets": [
    { "name": "Product Main", "category": "Product" }
  ]
}
{% endschema %}
