<div class="section-padding" data-section-type="product-main">
  <div class="container-page">
    {% if product %}
    {% assign product_display_title = product.metafields.custom.short_title.value | default: product.title %}
    <div class="grid md:grid-cols-2 gap-8 lg:gap-16">
      <!-- Product images gallery -->
      <div class="product-gallery">
        <div class="product-main-image rounded-2xl overflow-hidden bg-bg-card aspect-square mb-4">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="800"
              height="800"
              loading="eager"
              class="w-full h-full object-cover object-center"
              id="product-main-image"
            >
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="product-thumbnails grid grid-cols-4 gap-3">
            {% for image in product.images %}
              <button
                type="button"
                class="product-thumb rounded-lg overflow-hidden bg-bg-card border-2 {% if forloop.first %}border-accent-cyan{% else %}border-transparent{% endif %} aspect-square"
                data-image-src="{{ image | image_url: width: 800 }}"
              >
                <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: product.title | escape }}" width="200" height="200" loading="lazy" class="w-full h-full object-cover">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product info -->
      <div class="product-info">
        {% if product.vendor %}
          <p class="text-text-muted text-xs uppercase tracking-widest mb-2">{{ product.vendor }}</p>
        {% endif %}

        <h1 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">
          {{ product_display_title }}
        </h1>

        <!-- Rating -->
        {% if product.metafields.reviews.rating.value %}
          <div class="flex items-center gap-2 mb-6">
            {% render 'rating-stars', rating: product.metafields.reviews.rating.value %}
            <span class="text-text-muted text-sm">({{ product.metafields.reviews.rating_count.value }} reviews)</span>
          </div>
        {% endif %}

        <!-- Price -->
        <div class="mb-6 pb-6 border-b border-gray-800">
          {% render 'price', product: product %}
        </div>

        <!-- Variant selectors -->
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="mb-5">
              <label class="block text-sm text-text-muted uppercase tracking-wider mb-3">
                {{ option.name }}: <span class="text-white font-semibold">{{ option.selected_value }}</span>
              </label>
              {% if option.name == 'Color' or option.name == 'Colour' %}
                <div class="flex flex-wrap gap-3">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="color-option w-10 h-10 rounded-full border-2 {% if value == option.selected_value %}border-accent-cyan{% else %}border-gray-700{% endif %} transition-colors"
                      style="background-color: {{ value | handleize }}"
                      data-variant-id=""
                      data-option-value="{{ value | escape }}"
                      title="{{ value }}"
                    >
                    </button>
                  {% endfor %}
                </div>
              {% else %}
                <div class="flex flex-wrap gap-2">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="variant-option px-5 py-2 rounded-lg border {% if value == option.selected_value %}border-accent-cyan text-accent-cyan bg-accent-cyan/5{% else %}border-gray-700 text-text-secondary{% endif %} hover:border-accent-cyan transition-colors text-sm font-mono"
                      data-option-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {% endunless %}

        <!-- Add to cart -->
        {% form 'product', product, id: 'ProductForm', class: 'flex items-center gap-4 mb-6 pt-4' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div class="flex items-center border border-gray-700 rounded-xl">
            <button type="button" class="qty-btn px-4 py-3 text-text-muted hover:text-accent-cyan transition-colors" data-action="decrease">-</button>
            <input type="number" name="quantity" value="1" min="1" class="qty-input w-16 text-center border-0 bg-transparent text-white font-mono text-sm" readonly>
            <button type="button" class="qty-btn px-4 py-3 text-text-muted hover:text-accent-cyan transition-colors" data-action="increase">+</button>
          </div>

          <button
            type="submit"
            class="btn-primary flex-1 add-to-cart-btn"
            data-variant-id="{{ product.first_available_variant.id }}"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}
              {% render 'icon' with 'shopping-cart' %}
              {{ 'products.product.add_to_cart' | t }}
            {% else %}
              {{ 'products.product.sold_out' | t }}
            {% endif %}
          </button>
        {% endform %}

        <!-- Product accordion (tech specs) -->
        <div class="product-accordions mt-8 space-y-3">
          {% if product.description != blank %}
            <details class="product-accordion bg-bg-card rounded-xl">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
                <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">{{ 'products.product.description' | t }}</span>
                <span class="accordion-icon text-accent-cyan">+</span>
              </summary>
              <div class="px-6 pb-6 text-text-secondary rte">
                {{ product.description }}
              </div>
            </details>
          {% endif %}

          {% if product.metafields.custom.tech_specs %}
            <details class="product-accordion bg-bg-card rounded-xl">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
                <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">Tech Specs</span>
                <span class="accordion-icon text-accent-cyan">+</span>
              </summary>
              <div class="px-6 pb-6">
                <table class="w-full text-sm">
                  {% for spec in product.metafields.custom.tech_specs.value %}
                    <tr class="border-b border-gray-800 last:border-0">
                      <td class="py-3 text-text-muted font-mono uppercase tracking-wider text-xs">{{ spec[0] }}</td>
                      <td class="py-3 text-white font-mono text-right">{{ spec[1] }}</td>
                    </tr>
                  {% endfor %}
                </table>
              </div>
            </details>
          {% endif %}

          <details class="product-accordion bg-bg-card rounded-xl">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer">
              <span class="font-mono text-sm text-accent-cyan uppercase tracking-wider">Shipping & Returns</span>
              <span class="accordion-icon text-accent-cyan">+</span>
            </summary>
            <div class="px-6 pb-6 text-text-secondary text-sm space-y-2">
              <p>Free standard shipping on orders over $50.</p>
              <p>Express shipping available at checkout.</p>
              <p>30-day hassle-free return policy.</p>
            </div>
          </details>
        </div>

        <!-- Compatibility badges -->
        <div class="flex flex-wrap gap-3 mt-8 pt-6 border-t border-gray-800">
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'monitor' %} PC
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} Xbox Series X|S
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} PS5
          </span>
          <span class="flex items-center gap-2 text-xs text-text-muted bg-primary-blue px-3 py-2 rounded-lg">
            {% render 'icon' with 'gamepad' %} Switch
          </span>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
</div>

<style>
  .product-accordion summary {
    list-style: none;
  }
  .product-accordion summary::-webkit-details-marker { display: none; }
  .product-accordion[open] .accordion-icon {
    transform: rotate(45deg);
  }
  .accordion-icon { transition: transform 0.3s; font-size: 1.2rem; }
</style>

<script>
(function() {
  // Thumbnail switcher
  document.querySelectorAll('.product-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var src = btn.getAttribute('data-image-src');
      var mainImg = document.getElementById('product-main-image');
      if (mainImg && src) mainImg.src = src;

      document.querySelectorAll('.product-thumb').forEach(function(t) {
        t.classList.remove('border-accent-cyan');
        t.classList.add('border-transparent');
      });
      btn.classList.add('border-accent-cyan');
      btn.classList.remove('border-transparent');
    });
  });

  // Quantity selector
  var qtyInput = document.querySelector('.qty-input');
  document.querySelectorAll('.qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value) || 1;
      if (btn.dataset.action === 'increase') qtyInput.value = val + 1;
      else if (btn.dataset.action === 'decrease' && val > 1) qtyInput.value = val - 1;
    });
  });

  // Add to cart
  var addBtn = document.querySelector('.add-to-cart-btn');
  if (addBtn) {
    addBtn.addEventListener('click', function(event) {
      event.preventDefault();
      var variantId = addBtn.dataset.variantId;
      var qty = parseInt(qtyInput?.value || 1);
      if (!variantId) return;

      addBtn.classList.add('loading');
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        addBtn.classList.remove('loading');
        addBtn.innerHTML = '&#10003; Added to Cart';
        setTimeout(function() { addBtn.innerHTML = addBtn.dataset.originalText || 'Add to Cart'; }, 2000);
        document.dispatchEvent(new CustomEvent('cart:updated'));
      })
      .catch(function(err) {
        console.error(err);
        addBtn.classList.remove('loading');
      });
    });
    addBtn.dataset.originalText = addBtn.innerHTML;
  }
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "class": "product-main",
  "presets": [
    { "name": "Product Main", "category": "Product" }
  ]
}
{% endschema %}
