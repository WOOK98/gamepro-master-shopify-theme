{% comment %} Product card used in collection/product grids {% endcomment %}
{% assign image = product.featured_image | default: product.images.first %}
{% assign product_card_title = product.metafields.custom.short_title.value | default: product.title %}
{% assign product_image_alt = image.alt | default: product.title %}
{% assign product_sales_count = product.metafields.custom.sales_count.value %}

<div class="product-card group" data-product-handle="{{ product.handle }}">
  <div class="product-card-image relative overflow-hidden rounded-2xl bg-bg-card aspect-square mb-4">
    <a href="{{ product.url | within: collection }}" class="product-card-media-link block w-full h-full" aria-label="{{ product_card_title | escape }}">
      {% if image %}
        <img
          src="{{ image | image_url: width: 600 }}"
          alt="{{ product_image_alt | escape }}"
          width="600"
          height="600"
          loading="lazy"
          class="w-full h-full object-contain object-center transition-transform duration-500 group-hover:scale-105"
        >
      {% else %}
        <div class="w-full h-full flex items-center justify-center text-text-muted">
          {% render 'icon' with 'package' %}
        </div>
      {% endif %}
    </a>

    <!-- Product badges -->
    <div class="absolute top-3 left-3 flex flex-col gap-1.5 pointer-events-none">
        {% if product.available == false %}
          <span class="badge badge-soldout">{{ 'products.product.sold_out' | t }}</span>
        {% elsif product.compare_at_price > product.price %}
          <span class="badge badge-sale">{{ 'products.product.on_sale' | t }}</span>
        {% endif %}

        {% if product.tags contains 'new' %}
          <span class="badge badge-new">{{ 'products.product.new' | t }}</span>
        {% endif %}
    </div>

    {% if product.available %}
      <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity">
        {% if product.has_only_default_variant %}
          {% form 'product', product, class: 'product-card-form' %}
            <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="quick-add-btn bg-accent-cyan text-primary-blue p-3 rounded-xl hover:bg-white transition-colors"
              aria-label="{{ 'products.product.add_to_cart' | t }}: {{ product_card_title | escape }}"
            >
              {% render 'icon' with 'shopping-cart' %}
            </button>
          {% endform %}
        {% else %}
          <a
            href="{{ product.url | within: collection }}"
            class="quick-add-btn bg-accent-cyan text-primary-blue px-4 py-3 rounded-xl hover:bg-white transition-colors text-xs font-bold"
            aria-label="Choose options for {{ product_card_title | escape }}"
          >
            Choose options
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <a href="{{ product.url | within: collection }}" class="product-card-link block">
    <!-- Product info -->
    <div class="product-card-info">
      {% if show_vendor and product.vendor %}
        <p class="text-text-muted text-xs uppercase tracking-widest mb-1">{{ product.vendor }}</p>
      {% endif %}

      <h3 class="font-serif text-white font-bold text-base mb-2 group-hover:text-accent-cyan transition-colors line-clamp-2">
        {{ product_card_title | truncate: 78 }}
      </h3>

      {% if show_rating and product.metafields.reviews.rating.value %}
        <div class="mb-2">
          {% render 'rating-stars', rating: product.metafields.reviews.rating.value %}
        </div>
      {% endif %}

      {% render 'price', product: product %}

      {% if settings.show_sales_count and product_sales_count != blank %}
        <p class="concept-sales-count concept-sales-count--card">{{ product_sales_count }} sold</p>
      {% endif %}

      {% if show_platforms and product.tags %}
        <div class="flex flex-wrap gap-1 mt-3 pt-3 border-t border-gray-800">
          {% for tag in product.tags %}
            {% if tag contains 'platform:' %}
              <span class="text-xs text-text-muted bg-primary-blue/50 px-2 py-0.5 rounded">{{ tag | remove: 'platform:' }}</span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </a>
</div>

<style>
  .badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 0.5rem;
  }
  .badge-soldout { background: rgba(255,255,255,0.1); color: #94A3B8; }
  .badge-sale { background: rgba(255,46,99,0.9); color: white; }
  .badge-new { background: rgba(8,217,214,0.9); color: #0A192F; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
