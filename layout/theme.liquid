<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary_bg }}">
<!-- DeepLumen Bidirectional Canonical v1 START -->
{%- if template contains 'product' and product.metafields.deeplumen.ap_deployed.value == true -%}
  <link rel="canonical" href="https://{{ request.host }}/a/shop/products/{{ product.handle }}">
{%- elsif template contains 'collection' and collection.metafields.deeplumen.ap_deployed.value == true -%}
  <link rel="canonical" href="https://{{ request.host }}/a/shop/collections/{{ collection.handle }}">
{%- elsif template contains 'article' and article.metafields.deeplumen.ap_deployed.value == true -%}
  <link rel="canonical" href="https://{{ request.host }}/a/shop/blogs/{{ blog.handle }}/{{ article.handle }}">
{%- else -%}
  <link rel="canonical" href="{{ canonical_url }}">
{%- endif -%}
<!-- DeepLumen Bidirectional Canonical END -->
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {% assign seo_description = page_description | default: shop.description | default: settings.seo_default_description %}
  {% if seo_description == blank %}
    {% assign seo_description = 'Shop MIG Flash V2, MIG Flash Dumper, Switch 2 accessories, controllers, chargers, adapters, and setup gear from MIG Master.' %}
  {% endif %}
  {% assign seo_image_url = blank %}
  {% if request.page_type == 'product' and product.featured_image %}
    {% assign seo_image_url = product.featured_image | image_url: width: 1200 | prepend: 'https:' %}
  {% elsif settings.share_image %}
    {% assign seo_image_url = settings.share_image | image_url: width: 1200 | prepend: 'https:' %}
  {% else %}
    {% assign seo_image_url = 'hero-mig-flash.png' | asset_url | prepend: 'https:' %}
  {% endif %}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  <meta name="description" content="{{ seo_description | strip_html | strip | truncate: 160 | escape }}">

  <meta property="og:site_name" content="{{ shop.name | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">
  <meta property="og:description" content="{{ seo_description | strip_html | strip | truncate: 200 | escape }}">
  <meta property="og:image" content="{{ seo_image_url }}">
  <meta property="og:image:secure_url" content="{{ seo_image_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  <meta name="twitter:description" content="{{ seo_description | strip_html | strip | truncate: 200 | escape }}">
  <meta name="twitter:image" content="{{ seo_image_url }}">

  <!-- Structured data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "{{ shop.name }}",
      "url": "{{ shop.url }}",
      "logo": "{{ 'logo-migflash.png' | asset_url | prepend: 'https:' }}",
      "description": {{ seo_description | strip_html | strip | json }},
      "sameAs": [
        {{ settings.social_twitter | default: 'https://x.com/migmastershop' | json }}
      ]
    }
  </script>

  {% if request.page_type == 'product' and product %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": {{ product.title | json }},
        "description": {{ product.description | strip_html | truncate: 500 | json }},
        "url": {{ canonical_url | json }},
        {% if product.featured_image %}
          {% assign seo_product_image_url = product.featured_image | image_url: width: 1200 %}
          "image": [
            "{{ shop.url }}{{ seo_product_image_url }}"
          ],
        {% endif %}
        "brand": {
          "@type": "Brand",
          "name": {{ product.vendor | default: shop.name | json }}
        },
        "sku": {{ product.selected_or_first_available_variant.sku | default: product.selected_or_first_available_variant.id | json }},
        "offers": {
          "@type": "Offer",
          "url": {{ canonical_url | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
          "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
          "itemCondition": "https://schema.org/NewCondition"
        }
      }
    </script>
  {% endif %}

  <!-- Theme CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'concept.css' | asset_url | stylesheet_tag }}

  <!-- Header hook for plugins -->
  {{ content_for_header }}
</head>

<body class="template-{{ template | handle }} concept-store">

  {% section 'header' %}

  {% assign promo_discount_code = settings.promo_discount_code | default: 'F9VPVX2JG9KZ' %}
  {% assign promo_rail_text = settings.promo_rail_text | default: 'GET 5% OFF' %}

  <aside class="concept-social-rail" aria-label="Social media and promotion">
    <a href="{{ settings.social_twitter | default: 'https://x.com/migmastershop' }}" aria-label="X" target="_blank" rel="noopener">X</a>
    <a href="{{ settings.social_instagram | default: '#' }}" aria-label="Instagram">◎</a>
    <a href="{{ settings.social_youtube | default: '#' }}" aria-label="YouTube">▶</a>
    <a
      class="concept-social-promo"
      href="#discount-code"
      data-discount-trigger
      aria-label="{{ promo_rail_text }} discount"
    >
      {{ promo_rail_text }}
    </a>
  </aside>

  <div class="concept-discount-modal" data-discount-modal hidden>
    <div class="concept-discount-backdrop" data-discount-close></div>
    <div
      class="concept-discount-dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ConceptDiscountTitle"
    >
      <button class="concept-discount-close" type="button" data-discount-close aria-label="Close discount popup">×</button>
      <p class="concept-discount-eyebrow">{{ promo_rail_text }}</p>
      {% form 'customer', id: 'ConceptDiscountForm', class: 'concept-discount-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, discount-5">
        <input type="hidden" name="contact[accepts_marketing]" value="true">
        <input type="hidden" name="return_to" value="{{ request.path }}#discount-code">

        {% if form.posted_successfully? %}
          <h2 id="ConceptDiscountTitle">Your discount code:</h2>
          <button class="concept-discount-code" type="button" data-discount-copy data-code="{{ promo_discount_code }}">
            <span>{{ promo_discount_code }}</span>
            <small>Copy</small>
          </button>
          <p class="concept-discount-note">5% off entire order · One use per customer</p>
          <a class="concept-discount-shop" href="{{ routes.all_products_collection_url }}">Shop now</a>
        {% else %}
          <h2 id="ConceptDiscountTitle">Get 5% off your order</h2>
          <p class="concept-discount-note">Enter your email to receive the discount code. We use Shopify's form protection to reduce bot signups.</p>
          {% if form.errors %}
            <div class="concept-discount-error" id="ConceptDiscountError" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}
          <label class="visually-hidden" for="ConceptDiscountEmail">Email</label>
          <input
            id="ConceptDiscountEmail"
            class="concept-discount-input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            aria-required="true"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="ConceptDiscountError"
            {% elsif form.posted_successfully? %}
              aria-describedby="ConceptDiscountTitle"
            {% endif %}
            placeholder="Email"
            required
          >
          <button class="concept-discount-submit" type="submit" name="commit">Get discount code</button>
          <p class="concept-discount-legal">By signing up, you agree to receive marketing emails. You can unsubscribe anytime.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>

  <main role="main" id="MainContent">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Theme JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

</body>
</html>
